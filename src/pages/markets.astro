---
/**
 * 市场行情页面
 */
import MainLayout from '@/layouts/MainLayout.astro';
---

<MainLayout 
  title="Cryptocurrency Market Prices - Live Bitcoin & Ethereum Prices"
  description="View live cryptocurrency prices and market data for Bitcoin, Ethereum, BNB, XRP, and more. Track 24h price changes, trading volumes, and market trends in real-time."
  keywords="cryptocurrency prices, bitcoin price, ethereum price, crypto market data, live crypto prices, BTC price, ETH price, market cap, trading volume, price charts"
>
  <div class="min-h-screen bg-gray-50 py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- 页头 -->
      <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Crypto Markets</h1>
        <p class="mt-2 text-sm text-gray-600">
          Real-time cryptocurrency prices and charts
        </p>
      </div>

      <!-- 搜索和筛选 -->
      <div class="mb-6 flex items-center justify-between">
        <div class="flex-1 max-w-lg">
          <input
            type="text"
            id="search-input"
            placeholder="Search trading pair..."
            class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500"
          />
        </div>
        <div class="ml-4">
          <button
            id="refresh-button"
            class="px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500"
          >
            🔄 Refresh
          </button>
        </div>
      </div>

      <!-- 市场列表 -->
      <div class="bg-white rounded-lg shadow overflow-hidden">
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                  Trading Pair
                </th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
                  Last Price
                </th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
                  24h Change
                </th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
                  24h High
                </th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
                  24h Low
                </th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
                  24h Volume
                </th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
                  Action
                </th>
              </tr>
            </thead>
            <tbody id="markets-table" class="bg-white divide-y divide-gray-200">
              <!-- 市场数据将通过 JS 动态插入 -->
              <tr>
                <td colspan="7" class="px-6 py-8 text-center text-gray-500">
                  Loading market data...
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- 最后更新时间 -->
      <div class="mt-4 text-center text-sm text-gray-500">
        Last updated: <span id="last-updated">--</span>
        <span class="ml-4">Auto-refresh in <span id="countdown">10</span>s</span>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  let refreshInterval: number;
  let countdownInterval: number;
  let countdown = 10;

  // 加载市场数据
  async function loadMarkets() {
    try {
      const response = await fetch('/api/market/tickers');
      
      if (!response.ok) {
        throw new Error('Failed to load market data');
      }

      const result = await response.json();
      const tickers = result.data;

      // 渲染市场表格
      const tbody = document.getElementById('markets-table')!;
      tbody.innerHTML = tickers.map((ticker: any) => {
        const change24h = parseFloat(ticker.change_24h);
        const isPositive = change24h >= 0;
        
        return `
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="flex items-center">
                <div class="text-sm font-medium text-gray-900">${ticker.trading_pair}</div>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium text-gray-900">
              $${parseFloat(ticker.price).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-semibold ${
              isPositive ? 'text-green-600' : 'text-red-600'
            }">
              ${isPositive ? '+' : ''}${change24h.toFixed(2)}%
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm text-gray-500">
              $${parseFloat(ticker.high_24h).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm text-gray-500">
              $${parseFloat(ticker.low_24h).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm text-gray-500">
              ${formatVolume(ticker.volume_24h)}
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
              <a
                href="/trade/${ticker.trading_pair.replace('/', '-')}"
                class="inline-flex items-center px-3 py-1 bg-indigo-600 text-white text-sm font-medium rounded-md hover:bg-indigo-700"
              >
                Trade
              </a>
            </td>
          </tr>
        `;
      }).join('');

      // 更新最后更新时间
      document.getElementById('last-updated')!.textContent = new Date().toLocaleTimeString();

      // 重置倒计时
      countdown = 10;
      document.getElementById('countdown')!.textContent = countdown.toString();
    } catch (error) {
      console.error('Error loading markets:', error);
      const tbody = document.getElementById('markets-table')!;
      tbody.innerHTML = `
        <tr>
          <td colspan="7" class="px-6 py-8 text-center text-red-600">
            Failed to load market data. Please try again.
          </td>
        </tr>
      `;
    }
  }

  // 格式化交易量
  function formatVolume(volume: string): string {
    const num = parseFloat(volume);
    if (num >= 1e9) {
      return `$${(num / 1e9).toFixed(2)}B`;
    } else if (num >= 1e6) {
      return `$${(num / 1e6).toFixed(2)}M`;
    } else if (num >= 1e3) {
      return `$${(num / 1e3).toFixed(2)}K`;
    } else {
      return `$${num.toFixed(2)}`;
    }
  }

  // 搜索功能
  document.getElementById('search-input')!.addEventListener('input', (e) => {
    const searchTerm = (e.target as HTMLInputElement).value.toLowerCase();
    const rows = document.querySelectorAll('#markets-table tr');
    
    rows.forEach((row) => {
      const tradingPair = row.querySelector('.text-sm.font-medium')?.textContent?.toLowerCase();
      if (tradingPair && tradingPair.includes(searchTerm)) {
        (row as HTMLElement).style.display = '';
      } else {
        (row as HTMLElement).style.display = 'none';
      }
    });
  });

  // 手动刷新
  document.getElementById('refresh-button')!.addEventListener('click', () => {
    loadMarkets();
  });

  // 倒计时
  function startCountdown() {
    countdownInterval = window.setInterval(() => {
      countdown--;
      document.getElementById('countdown')!.textContent = countdown.toString();
      
      if (countdown <= 0) {
        countdown = 10;
      }
    }, 1000);
  }

  // 自动刷新
  function startAutoRefresh() {
    refreshInterval = window.setInterval(() => {
      loadMarkets();
    }, 10000); // 每10秒刷新一次
  }

  // 页面加载时执行
  loadMarkets();
  startAutoRefresh();
  startCountdown();

  // 页面卸载时清除定时器
  window.addEventListener('beforeunload', () => {
    clearInterval(refreshInterval);
    clearInterval(countdownInterval);
  });
</script>
