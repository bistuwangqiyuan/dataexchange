---
/**
 * Orders Page
 * 订单管理页面 - 显示当前委托和历史订单
 */

import MainLayout from '@/layouts/MainLayout.astro';
---

<MainLayout title="订单管理 - CryptoEx">
  <div class="container py-8">
    <div class="mb-6">
      <h1 class="text-3xl font-bold mb-2">订单管理</h1>
      <p class="text-gray-600 dark:text-gray-400">
        查看和管理您的交易订单
      </p>
    </div>

    <!-- Tab 切换 -->
    <div class="mb-6">
      <div class="border-b border-gray-200 dark:border-gray-700">
        <nav class="-mb-px flex gap-8">
          <button
            id="activeTab"
            class="tab-button active"
            data-tab="active"
          >
            当前委托
          </button>
          <button
            id="historyTab"
            class="tab-button"
            data-tab="history"
          >
            历史订单
          </button>
        </nav>
      </div>
    </div>

    <!-- 筛选器 -->
    <div class="card mb-6" id="filterSection">
      <div class="p-4">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
          <div>
            <label class="block text-sm font-medium mb-2">交易对</label>
            <select id="filterPair" class="input">
              <option value="">全部</option>
              <option value="BTC/USDT">BTC/USDT</option>
              <option value="ETH/USDT">ETH/USDT</option>
              <option value="BNB/USDT">BNB/USDT</option>
              <option value="SOL/USDT">SOL/USDT</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium mb-2">状态</label>
            <select id="filterStatus" class="input">
              <option value="">全部</option>
              <option value="pending">待成交</option>
              <option value="filled">已成交</option>
              <option value="cancelled">已取消</option>
              <option value="partially_filled">部分成交</option>
            </select>
          </div>
          <div class="flex items-end">
            <button
              id="applyFilterBtn"
              class="btn btn-primary w-full"
            >
              应用筛选
            </button>
          </div>
          <div class="flex items-end">
            <button
              id="resetFilterBtn"
              class="btn btn-secondary w-full"
            >
              重置
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- 当前委托内容 -->
    <div id="activeOrdersContent" class="tab-content">
      <div class="card">
        <div class="p-6">
          <div class="flex justify-between items-center mb-4">
            <h2 class="text-xl font-bold">当前委托订单</h2>
            <button
              id="refreshActiveBtn"
              class="text-primary-600 hover:text-primary-700 text-sm font-medium"
            >
              刷新
            </button>
          </div>
          <div id="activeOrdersContainer">
            <div class="text-center py-8">
              <div class="spinner w-8 h-8 mx-auto mb-2"></div>
              <p class="text-gray-600 dark:text-gray-400">加载订单中...</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 历史订单内容 -->
    <div id="historyOrdersContent" class="tab-content hidden">
      <div class="card">
        <div class="p-6">
          <div class="flex justify-between items-center mb-4">
            <h2 class="text-xl font-bold">历史订单</h2>
            <button
              id="refreshHistoryBtn"
              class="text-primary-600 hover:text-primary-700 text-sm font-medium"
            >
              刷新
            </button>
          </div>
          <div id="historyOrdersContainer">
            <div class="text-center py-8">
              <div class="spinner w-8 h-8 mx-auto mb-2"></div>
              <p class="text-gray-600 dark:text-gray-400">加载订单中...</p>
            </div>
          </div>
          <!-- 分页 -->
          <div id="paginationContainer" class="mt-6 flex justify-center"></div>
        </div>
      </div>
    </div>
  </div>

  <script>
    let currentPage = 1;
    const pageSize = 20;

    // Tab 切换
    function switchTab(tab: string) {

      // 更新按钮样式
      document.querySelectorAll('.tab-button').forEach(btn => {
        btn.classList.remove('active');
      });
      document.getElementById(tab + 'Tab')?.classList.add('active');

      // 更新内容显示
      document.querySelectorAll('.tab-content').forEach(content => {
        content.classList.add('hidden');
      });
      document.getElementById(tab + 'OrdersContent')?.classList.remove('hidden');

      // 加载数据
      if (tab === 'active') {
        fetchActiveOrders();
      } else {
        fetchHistoryOrders();
      }
    }

    // 获取活跃订单
    async function fetchActiveOrders() {
      try {
        const response = await fetch('/api/orders/active');
        const result = await response.json();

        const container = document.getElementById('activeOrdersContainer');
        if (!container) return;

        if (result.success && result.data && result.data.length > 0) {
          container.innerHTML = `
            <div class="overflow-x-auto">
              <table class="table">
                <thead>
                  <tr>
                    <th>交易对</th>
                    <th>类型</th>
                    <th>方向</th>
                    <th class="text-right">价格</th>
                    <th class="text-right">数量</th>
                    <th class="text-right">已成交</th>
                    <th>时间</th>
                    <th>操作</th>
                  </tr>
                </thead>
                <tbody>
                  ${result.data.map((order: any) => `
                    <tr>
                      <td class="font-medium">${order.trading_pair}</td>
                      <td>${order.order_type === 'market' ? '市价' : '限价'}</td>
                      <td class="${order.side === 'buy' ? 'text-green-600' : 'text-red-600'} font-medium">
                        ${order.side === 'buy' ? '买入' : '卖出'}
                      </td>
                      <td class="text-right font-mono">${order.price || '市价'}</td>
                      <td class="text-right font-mono">${parseFloat(order.quantity).toFixed(8)}</td>
                      <td class="text-right font-mono">${parseFloat(order.filled_quantity).toFixed(8)}</td>
                      <td class="text-sm text-gray-600">${new Date(order.created_at).toLocaleString('zh-CN')}</td>
                      <td>
                        <button
                          onclick="cancelOrder('${order.id}')"
                          class="text-red-600 hover:text-red-700 text-sm font-medium"
                        >
                          取消
                        </button>
                      </td>
                    </tr>
                  `).join('')}
                </tbody>
              </table>
            </div>
          `;
        } else {
          container.innerHTML = `
            <div class="text-center py-8">
              <p class="text-gray-600 dark:text-gray-400">暂无委托订单</p>
              <p class="text-sm text-gray-500 dark:text-gray-500 mt-2">
                <a href="/trade" class="text-primary-600 hover:text-primary-700">前往交易页面</a>
                创建订单
              </p>
            </div>
          `;
        }
      } catch (error) {
        console.error('Failed to fetch active orders:', error);
      }
    }

    // 获取历史订单
    async function fetchHistoryOrders() {
      try {
        const filterPair = (document.getElementById('filterPair') as HTMLSelectElement)?.value;
        const filterStatus = (document.getElementById('filterStatus') as HTMLSelectElement)?.value;

        let url = `/api/orders/history?page=${currentPage}&page_size=${pageSize}`;
        if (filterPair) url += `&trading_pair=${filterPair}`;
        if (filterStatus) url += `&status=${filterStatus}`;

        const response = await fetch(url);
        const result = await response.json();

        const container = document.getElementById('historyOrdersContainer');
        if (!container) return;

        if (result.success && result.data && result.data.items.length > 0) {
          container.innerHTML = `
            <div class="overflow-x-auto">
              <table class="table">
                <thead>
                  <tr>
                    <th>交易对</th>
                    <th>类型</th>
                    <th>方向</th>
                    <th class="text-right">价格</th>
                    <th class="text-right">数量</th>
                    <th class="text-right">已成交</th>
                    <th>状态</th>
                    <th>时间</th>
                  </tr>
                </thead>
                <tbody>
                  ${result.data.items.map((order: any) => `
                    <tr>
                      <td class="font-medium">${order.trading_pair}</td>
                      <td>${order.order_type === 'market' ? '市价' : '限价'}</td>
                      <td class="${order.side === 'buy' ? 'text-green-600' : 'text-red-600'} font-medium">
                        ${order.side === 'buy' ? '买入' : '卖出'}
                      </td>
                      <td class="text-right font-mono">${order.price || '市价'}</td>
                      <td class="text-right font-mono">${parseFloat(order.quantity).toFixed(8)}</td>
                      <td class="text-right font-mono">${parseFloat(order.filled_quantity).toFixed(8)}</td>
                      <td>
                        <span class="text-xs px-2 py-1 rounded-full ${
                          order.status === 'filled' ? 'bg-green-100 text-green-700' :
                          order.status === 'cancelled' ? 'bg-gray-100 text-gray-700' :
                          order.status === 'partially_filled' ? 'bg-yellow-100 text-yellow-700' :
                          'bg-blue-100 text-blue-700'
                        }">
                          ${
                            order.status === 'filled' ? '已成交' :
                            order.status === 'cancelled' ? '已取消' :
                            order.status === 'partially_filled' ? '部分成交' :
                            '待成交'
                          }
                        </span>
                      </td>
                      <td class="text-sm text-gray-600">${new Date(order.created_at).toLocaleString('zh-CN')}</td>
                    </tr>
                  `).join('')}
                </tbody>
              </table>
            </div>
          `;

          // 更新分页
          updatePagination(result.data.total_pages);
        } else {
          container.innerHTML = `
            <div class="text-center py-8">
              <p class="text-gray-600 dark:text-gray-400">暂无历史订单</p>
            </div>
          `;
          document.getElementById('paginationContainer')!.innerHTML = '';
        }
      } catch (error) {
        console.error('Failed to fetch history orders:', error);
      }
    }

    // 更新分页
    function updatePagination(totalPages: number) {
      const container = document.getElementById('paginationContainer');
      if (!container || totalPages <= 1) {
        container!.innerHTML = '';
        return;
      }

      let paginationHTML = '<div class="flex gap-2">';
      
      // 上一页
      paginationHTML += `
        <button
          onclick="changePage(${currentPage - 1})"
          class="btn btn-secondary ${currentPage === 1 ? 'opacity-50 cursor-not-allowed' : ''}"
          ${currentPage === 1 ? 'disabled' : ''}
        >
          上一页
        </button>
      `;

      // 页码
      for (let i = 1; i <= totalPages; i++) {
        if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) {
          paginationHTML += `
            <button
              onclick="changePage(${i})"
              class="btn ${i === currentPage ? 'btn-primary' : 'btn-secondary'}"
            >
              ${i}
            </button>
          `;
        } else if (i === currentPage - 3 || i === currentPage + 3) {
          paginationHTML += '<span class="px-2">...</span>';
        }
      }

      // 下一页
      paginationHTML += `
        <button
          onclick="changePage(${currentPage + 1})"
          class="btn btn-secondary ${currentPage === totalPages ? 'opacity-50 cursor-not-allowed' : ''}"
          ${currentPage === totalPages ? 'disabled' : ''}
        >
          下一页
        </button>
      `;

      paginationHTML += '</div>';
      container.innerHTML = paginationHTML;
    }

    // 更改页码
    (window as any).changePage = function(page: number) {
      currentPage = page;
      fetchHistoryOrders();
    };

    // 取消订单
    (window as any).cancelOrder = async function(orderId: string) {
      if (!confirm('确定要取消这个订单吗？')) {
        return;
      }

      try {
        const response = await fetch(`/api/orders/cancel/${orderId}`, {
          method: 'POST',
        });

        const result = await response.json();

        if (result.success) {
          alert('订单已取消');
          fetchActiveOrders();
        } else {
          alert(result.error?.message || '取消失败');
        }
      } catch (error) {
        alert('网络错误，请重试');
      }
    };

    // Tab 按钮事件
    document.getElementById('activeTab')?.addEventListener('click', () => switchTab('active'));
    document.getElementById('historyTab')?.addEventListener('click', () => switchTab('history'));

    // 刷新按钮
    document.getElementById('refreshActiveBtn')?.addEventListener('click', fetchActiveOrders);
    document.getElementById('refreshHistoryBtn')?.addEventListener('click', fetchHistoryOrders);

    // 筛选按钮
    document.getElementById('applyFilterBtn')?.addEventListener('click', () => {
      currentPage = 1;
      fetchHistoryOrders();
    });

    document.getElementById('resetFilterBtn')?.addEventListener('click', () => {
      (document.getElementById('filterPair') as HTMLSelectElement).value = '';
      (document.getElementById('filterStatus') as HTMLSelectElement).value = '';
      currentPage = 1;
      fetchHistoryOrders();
    });

    // 初始加载
    fetchActiveOrders();
  </script>

  <style>
    .tab-button {
      @apply py-4 px-1 border-b-2 border-transparent text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 hover:border-gray-300 font-medium transition-colors;
    }

    .tab-button.active {
      @apply text-primary-600 border-primary-600;
    }
  </style>
</MainLayout>
