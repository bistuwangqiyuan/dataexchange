---
/**
 * Login Page
 * 登录页面
 */

import MainLayout from '@/layouts/MainLayout.astro';
---

<MainLayout title="登录 - CryptoEx">
  <div class="min-h-[calc(100vh-200px)] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full">
      <div class="card">
        <div class="text-center mb-8">
          <h2 class="text-3xl font-bold">登录账号</h2>
          <p class="text-gray-600 dark:text-gray-400 mt-2">
            欢迎回来！请登录您的账号
          </p>
        </div>

        <form id="loginForm" class="space-y-6">
          <div>
            <label for="email" class="label">邮箱地址</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="input"
              placeholder="your@email.com"
            />
            <p id="emailError" class="error-text hidden"></p>
          </div>

          <div>
            <label for="password" class="label">密码</label>
            <input
              type="password"
              id="password"
              name="password"
              required
              class="input"
              placeholder="••••••••"
            />
            <p id="passwordError" class="error-text hidden"></p>
          </div>

          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <input
                id="remember"
                name="remember"
                type="checkbox"
                class="h-4 w-4 text-primary-600 focus:ring-primary-500 border-gray-300 rounded"
              />
              <label for="remember" class="ml-2 block text-sm text-gray-900 dark:text-gray-300">
                记住我
              </label>
            </div>

            <div class="text-sm">
              <a href="/forgot-password" class="font-medium text-primary-600 hover:text-primary-500">
                忘记密码？
              </a>
            </div>
          </div>

          <!-- 提示信息区域 -->
          <div id="formMessage" class="hidden px-4 py-3 rounded-lg">
            <div class="flex items-start">
              <span id="messageIcon" class="flex-shrink-0 mr-3 text-xl"></span>
              <div class="flex-1">
                <p id="messageText" class="font-medium"></p>
                <p id="messageDetail" class="text-sm mt-1 hidden"></p>
              </div>
            </div>
          </div>

          <button
            type="submit"
            id="submitButton"
            class="w-full btn btn-primary btn-lg"
          >
            登录
          </button>
        </form>

        <div class="mt-6 text-center">
          <p class="text-sm text-gray-600 dark:text-gray-400">
            还没有账号？
            <a href="/register" class="font-medium text-primary-600 hover:text-primary-500">
              立即注册
            </a>
          </p>
        </div>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('loginForm') as HTMLFormElement;
    const submitButton = document.getElementById('submitButton') as HTMLButtonElement;
    const formMessage = document.getElementById('formMessage') as HTMLDivElement;
    const messageIcon = document.getElementById('messageIcon') as HTMLSpanElement;
    const messageText = document.getElementById('messageText') as HTMLParagraphElement;
    const messageDetail = document.getElementById('messageDetail') as HTMLParagraphElement;
    const emailInput = document.getElementById('email') as HTMLInputElement;
    const passwordInput = document.getElementById('password') as HTMLInputElement;

    // 显示消息的辅助函数
    function showMessage(type: 'success' | 'error' | 'info' | 'loading', text: string, detail?: string) {
      formMessage.classList.remove('hidden');
      messageText.textContent = text;
      
      if (detail) {
        messageDetail.textContent = detail;
        messageDetail.classList.remove('hidden');
      } else {
        messageDetail.classList.add('hidden');
      }

      // 重置所有样式
      formMessage.className = 'px-4 py-3 rounded-lg';
      
      switch (type) {
        case 'success':
          formMessage.classList.add('bg-green-50', 'dark:bg-green-900/20', 'border', 'border-green-200', 'dark:border-green-800', 'text-green-600', 'dark:text-green-400');
          messageIcon.textContent = '✓';
          break;
        case 'error':
          formMessage.classList.add('bg-red-50', 'dark:bg-red-900/20', 'border', 'border-red-200', 'dark:border-red-800', 'text-red-600', 'dark:text-red-400');
          messageIcon.textContent = '✕';
          break;
        case 'info':
          formMessage.classList.add('bg-blue-50', 'dark:bg-blue-900/20', 'border', 'border-blue-200', 'dark:border-blue-800', 'text-blue-600', 'dark:text-blue-400');
          messageIcon.textContent = 'ℹ';
          break;
        case 'loading':
          formMessage.classList.add('bg-gray-50', 'dark:bg-gray-900/20', 'border', 'border-gray-200', 'dark:border-gray-800', 'text-gray-600', 'dark:text-gray-400');
          messageIcon.innerHTML = '<span class="spinner inline-block w-5 h-5"></span>';
          break;
      }
    }

    // 隐藏消息
    function hideMessage() {
      formMessage.classList.add('hidden');
    }

    // 实时验证邮箱格式
    emailInput.addEventListener('blur', () => {
      const email = emailInput.value.trim();
      if (email && !email.match(/^[^\s@]+@[^\s@]+\.[^\s@]+$/)) {
        showMessage('error', '邮箱格式不正确', '请输入有效的邮箱地址');
      } else if (formMessage.classList.contains('bg-red-50')) {
        hideMessage();
      }
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // 获取表单数据
      const formData = new FormData(form);
      const email = formData.get('email') as string;
      const password = formData.get('password') as string;

      // 前端验证
      if (!email || !password) {
        showMessage('error', '请填写所有必填项', '邮箱和密码不能为空');
        return;
      }

      if (!email.match(/^[^\s@]+@[^\s@]+\.[^\s@]+$/)) {
        showMessage('error', '邮箱格式不正确', '请输入有效的邮箱地址');
        return;
      }

      // 显示加载状态
      showMessage('loading', '正在验证登录信息...', '请稍候，这可能需要几秒钟');
      submitButton.disabled = true;
      submitButton.innerHTML = '<span class="spinner"></span> 登录中...';

      try {
        const response = await fetch('/api/auth/login', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ email, password }),
        });

        const result = await response.json();

        if (result.success) {
          // 登录成功
          showMessage('success', '登录成功！', '正在跳转到市场页面...');
          
          // 延迟跳转，让用户看到成功提示
          setTimeout(() => {
            window.location.href = '/markets';
          }, 800);
        } else {
          // 显示详细错误
          const errorMessage = result.error?.message || '登录失败';
          let errorDetail = '';
          
          if (errorMessage.includes('Invalid login credentials') || errorMessage.includes('invalid_credentials')) {
            errorDetail = '邮箱或密码错误，请检查后重试';
          } else if (errorMessage.includes('Email not confirmed')) {
            errorDetail = '请先确认您的邮箱地址';
          } else if (errorMessage.includes('User not found')) {
            errorDetail = '该账号不存在，请先注册';
          } else {
            errorDetail = '请稍后重试或联系客服';
          }
          
          showMessage('error', errorMessage, errorDetail);
          
          // 恢复按钮
          submitButton.disabled = false;
          submitButton.textContent = '登录';
        }
      } catch (error) {
        showMessage('error', '网络连接失败', '请检查您的网络连接后重试');
        
        // 恢复按钮
        submitButton.disabled = false;
        submitButton.textContent = '登录';
      }
    });
  </script>
</MainLayout>

