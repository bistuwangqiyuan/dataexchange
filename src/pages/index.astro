---
/**
 * Dashboard - 用户资产概览首页
 */
import MainLayout from '@/layouts/MainLayout.astro';
---

<MainLayout 
  title="Crypto Trading Platform - Trade Bitcoin, Ethereum & More"
  description="Professional cryptocurrency trading platform with real-time market data, advanced charting tools, and secure wallet management. Start trading Bitcoin, Ethereum, BNB, and other digital assets today."
  keywords="crypto trading, cryptocurrency exchange, bitcoin trading, ethereum trading, digital assets, crypto platform, trading platform, BTC, ETH, real-time market data"
>
  <div class="min-h-screen bg-gray-50 py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Welcome Header -->
      <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Welcome Back!</h1>
        <p class="mt-2 text-sm text-gray-600" id="user-email">Loading...</p>
      </div>

      <!-- Asset Overview Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <!-- Total Assets -->
        <div class="bg-white rounded-lg shadow p-6">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-gray-600">Total Assets</p>
              <p class="mt-2 text-3xl font-bold text-gray-900" id="total-assets">$0.00</p>
            </div>
            <div class="p-3 bg-indigo-100 rounded-full">
              <svg class="w-8 h-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
          </div>
        </div>

        <!-- 24h Change -->
        <div class="bg-white rounded-lg shadow p-6">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-gray-600">24h Change</p>
              <p class="mt-2 text-3xl font-bold" id="change-24h">+0.00%</p>
            </div>
            <div class="p-3 bg-green-100 rounded-full">
              <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
              </svg>
            </div>
          </div>
        </div>

        <!-- Active Orders -->
        <div class="bg-white rounded-lg shadow p-6">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-gray-600">Active Orders</p>
              <p class="mt-2 text-3xl font-bold text-gray-900" id="active-orders-count">0</p>
            </div>
            <div class="p-3 bg-blue-100 rounded-full">
              <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
              </svg>
            </div>
          </div>
        </div>

        <!-- Completed Trades -->
        <div class="bg-white rounded-lg shadow p-6">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-gray-600">Total Trades</p>
              <p class="mt-2 text-3xl font-bold text-gray-900" id="total-trades">0</p>
            </div>
            <div class="p-3 bg-purple-100 rounded-full">
              <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
          </div>
        </div>
      </div>

      <!-- Asset Distribution & Hot Markets -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
        <!-- Asset Distribution -->
        <div class="bg-white rounded-lg shadow p-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">Asset Distribution</h2>
          <div id="asset-distribution" class="space-y-3">
            <!-- Will be populated by JS -->
          </div>
        </div>

        <!-- Hot Markets -->
        <div class="bg-white rounded-lg shadow p-6">
          <div class="flex justify-between items-center mb-4">
            <h2 class="text-lg font-semibold text-gray-900">Hot Markets (24h)</h2>
            <a href="/markets" class="text-sm text-indigo-600 hover:text-indigo-800">View All →</a>
          </div>
          <div id="hot-markets" class="space-y-3">
            <!-- Will be populated by JS -->
          </div>
        </div>
      </div>

      <!-- Recent Activity -->
      <div class="bg-white rounded-lg shadow">
        <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
          <h2 class="text-lg font-semibold text-gray-900">Recent Activity</h2>
          <a href="/orders" class="text-sm text-indigo-600 hover:text-indigo-800">View All →</a>
        </div>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Time</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Pair</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Amount</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
              </tr>
            </thead>
            <tbody id="recent-activity" class="bg-white divide-y divide-gray-200">
              <tr>
                <td colspan="5" class="px-6 py-8 text-center text-gray-500">
                  Loading recent activity...
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/markets" class="block p-6 bg-white rounded-lg shadow hover:shadow-lg transition-shadow">
          <div class="flex items-center">
            <div class="p-3 bg-indigo-100 rounded-full">
              <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"></path>
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-lg font-semibold text-gray-900">View Markets</p>
              <p class="text-sm text-gray-600">Explore trading pairs</p>
            </div>
          </div>
        </a>

        <a href="/wallet" class="block p-6 bg-white rounded-lg shadow hover:shadow-lg transition-shadow">
          <div class="flex items-center">
            <div class="p-3 bg-green-100 rounded-full">
              <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path>
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-lg font-semibold text-gray-900">My Wallet</p>
              <p class="text-sm text-gray-600">Manage your assets</p>
            </div>
          </div>
        </a>

        <a href="/orders" class="block p-6 bg-white rounded-lg shadow hover:shadow-lg transition-shadow">
          <div class="flex items-center">
            <div class="p-3 bg-blue-100 rounded-full">
              <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-lg font-semibold text-gray-900">My Orders</p>
              <p class="text-sm text-gray-600">Track your trades</p>
            </div>
          </div>
        </a>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  const getToken = () => localStorage.getItem('access_token');

  // Redirect if not logged in
  if (!getToken()) {
    window.location.href = '/login';
  }

  // Price data for conversion (simplified)
  const priceData: Record<string, number> = {
    'BTC': 45000,
    'ETH': 3000,
    'USDT': 1,
    'BNB': 450,
    'XRP': 0.85,
    'ADA': 0.65,
  };

  // Load user profile
  async function loadUserProfile() {
    try {
      const response = await fetch('/api/user/profile', {
        headers: { 'Authorization': `Bearer ${getToken()}` },
      });

      if (response.ok) {
        const result = await response.json();
        document.getElementById('user-email')!.textContent = result.data.email;
      }
    } catch (error) {
      console.error('Error loading user profile:', error);
    }
  }

  // Load wallet balances
  async function loadWalletBalances() {
    try {
      const response = await fetch('/api/wallet/balances', {
        headers: { 'Authorization': `Bearer ${getToken()}` },
      });

      if (!response.ok) throw new Error('Failed to load balances');

      const result = await response.json();
      const wallets = result.data;

      // Calculate total assets
      const totalAssets = wallets.reduce((sum: number, wallet: any) => {
        const price = priceData[wallet.currency] || 0;
        return sum + parseFloat(wallet.balance) * price;
      }, 0);

      document.getElementById('total-assets')!.textContent = `$${totalAssets.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;

      // Render asset distribution
      const distributionDiv = document.getElementById('asset-distribution')!;
      distributionDiv.innerHTML = wallets
        .filter((w: any) => parseFloat(w.balance) > 0)
        .map((wallet: any) => {
          const value = parseFloat(wallet.balance) * (priceData[wallet.currency] || 0);
          const percentage = (value / totalAssets * 100).toFixed(1);
          return `
            <div class="flex items-center justify-between">
              <div class="flex items-center">
                <div class="w-12 h-12 bg-gradient-to-r from-indigo-500 to-purple-600 rounded-full flex items-center justify-center text-white font-bold text-sm">
                  ${wallet.currency}
                </div>
                <div class="ml-3">
                  <p class="text-sm font-medium text-gray-900">${wallet.currency}</p>
                  <p class="text-xs text-gray-500">${parseFloat(wallet.balance).toFixed(6)}</p>
                </div>
              </div>
              <div class="text-right">
                <p class="text-sm font-medium text-gray-900">$${value.toFixed(2)}</p>
                <p class="text-xs text-gray-500">${percentage}%</p>
              </div>
            </div>
          `;
        }).join('');
    } catch (error) {
      console.error('Error loading balances:', error);
    }
  }

  // Load active orders count
  async function loadActiveOrders() {
    try {
      const response = await fetch('/api/orders/active', {
        headers: { 'Authorization': `Bearer ${getToken()}` },
      });

      if (!response.ok) throw new Error('Failed to load orders');

      const result = await response.json();
      document.getElementById('active-orders-count')!.textContent = result.data.length.toString();
    } catch (error) {
      console.error('Error loading active orders:', error);
    }
  }

  // Load transaction count
  async function loadTransactionCount() {
    try {
      const response = await fetch('/api/transactions', {
        headers: { 'Authorization': `Bearer ${getToken()}` },
      });

      if (!response.ok) throw new Error('Failed to load transactions');

      const result = await response.json();
      document.getElementById('total-trades')!.textContent = result.data.pagination.total.toString();

      // Load recent activity
      const recentActivity = result.data.items.slice(0, 5);
      const tbody = document.getElementById('recent-activity')!;
      
      if (recentActivity.length === 0) {
        tbody.innerHTML = '<tr><td colspan="5" class="px-6 py-8 text-center text-gray-500">No recent activity</td></tr>';
        return;
      }

      tbody.innerHTML = recentActivity.map((tx: any) => `
        <tr>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            ${new Date(tx.created_at).toLocaleTimeString()}
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm">
            <span class="px-2 py-1 text-xs font-semibold rounded-full ${
              tx.type === 'buy' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'
            }">
              ${tx.type}
            </span>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">${tx.trading_pair}</td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-gray-900">
            ${parseFloat(tx.quantity).toFixed(6)}
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm">
            <span class="px-2 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-800">
              Completed
            </span>
          </td>
        </tr>
      `).join('');
    } catch (error) {
      console.error('Error loading transactions:', error);
    }
  }

  // Load hot markets
  async function loadHotMarkets() {
    try {
      const response = await fetch('/api/market/tickers');
      
      if (!response.ok) throw new Error('Failed to load markets');

      const result = await response.json();
      const tickers = result.data.slice(0, 5); // Top 5

      const hotMarketsDiv = document.getElementById('hot-markets')!;
      hotMarketsDiv.innerHTML = tickers.map((ticker: any) => {
        const change = parseFloat(ticker.change_24h);
        const isPositive = change >= 0;
        
        return `
          <a href="/trade/${ticker.trading_pair.replace('/', '-')}" class="flex items-center justify-between p-3 hover:bg-gray-50 rounded-lg transition-colors">
            <div>
              <p class="text-sm font-medium text-gray-900">${ticker.trading_pair}</p>
              <p class="text-xs text-gray-500">Vol: ${formatVolume(ticker.volume_24h)}</p>
            </div>
            <div class="text-right">
              <p class="text-sm font-medium text-gray-900">$${parseFloat(ticker.price).toLocaleString()}</p>
              <p class="text-xs font-semibold ${isPositive ? 'text-green-600' : 'text-red-600'}">
                ${isPositive ? '+' : ''}${change.toFixed(2)}%
              </p>
            </div>
          </a>
        `;
      }).join('');
    } catch (error) {
      console.error('Error loading hot markets:', error);
    }
  }

  function formatVolume(volume: string): string {
    const num = parseFloat(volume);
    if (num >= 1e9) return `$${(num / 1e9).toFixed(2)}B`;
    if (num >= 1e6) return `$${(num / 1e6).toFixed(2)}M`;
    if (num >= 1e3) return `$${(num / 1e3).toFixed(2)}K`;
    return `$${num.toFixed(2)}`;
  }

  // Load all dashboard data
  loadUserProfile();
  loadWalletBalances();
  loadActiveOrders();
  loadTransactionCount();
  loadHotMarkets();

  // Auto-refresh every 30 seconds
  setInterval(() => {
    loadWalletBalances();
    loadActiveOrders();
    loadHotMarkets();
  }, 30000);
</script>
