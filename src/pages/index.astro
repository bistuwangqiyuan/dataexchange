---
/**
 * Home Page
 * 首页
 */

import MainLayout from '@/layouts/MainLayout.astro';
---

<MainLayout title="首页 - CryptoEx 加密货币交易平台">
  <div class="bg-gradient-to-br from-primary-600 to-primary-800 text-white py-20">
    <div class="container">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-5xl md:text-6xl font-bold mb-6">
          安全、快速的加密货币交易平台
        </h1>
        <p class="text-xl md:text-2xl text-primary-100 mb-8">
          实时行情 · 极速交易 · 专业工具 · 安全保障
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/register" class="btn btn-lg bg-white text-primary-600 hover:bg-gray-100">
            立即注册
          </a>
          <a href="/markets" class="btn btn-lg bg-primary-700 hover:bg-primary-600 border-2 border-white">
            查看行情
          </a>
        </div>
        
        <div class="mt-8 inline-block">
          <p class="text-sm bg-yellow-500 text-yellow-900 px-4 py-2 rounded-full font-medium">
            ⚠️ 这是一个教育演示项目，使用模拟交易环境
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Features -->
  <div class="py-20">
    <div class="container">
      <h2 class="text-3xl font-bold text-center mb-12">核心功能</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Feature 1 -->
        <div class="card text-center">
          <div class="w-16 h-16 bg-primary-100 dark:bg-primary-900 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">实时行情</h3>
          <p class="text-gray-600 dark:text-gray-400">
            接入 CoinGecko 和 Binance API，提供真实的加密货币市场数据和行情走势
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="card text-center">
          <div class="w-16 h-16 bg-green-100 dark:bg-green-900 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">极速交易</h3>
          <p class="text-gray-600 dark:text-gray-400">
            支持市价单和限价单，模拟订单撮合机制，体验完整的交易流程
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="card text-center">
          <div class="w-16 h-16 bg-purple-100 dark:bg-purple-900 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">资产管理</h3>
          <p class="text-gray-600 dark:text-gray-400">
            多币种钱包管理，支持模拟充值和提现，完整的资产流水记录
          </p>
        </div>

        <!-- Feature 4 -->
        <div class="card text-center">
          <div class="w-16 h-16 bg-red-100 dark:bg-red-900 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">安全保障</h3>
          <p class="text-gray-600 dark:text-gray-400">
            Supabase RLS 数据安全，JWT 认证，完整的安全日志记录系统
          </p>
        </div>

        <!-- Feature 5 -->
        <div class="card text-center">
          <div class="w-16 h-16 bg-blue-100 dark:bg-blue-900 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">订单管理</h3>
          <p class="text-gray-600 dark:text-gray-400">
            完整的订单历史、成交记录、持仓管理，专业的交易工具
          </p>
        </div>

        <!-- Feature 6 -->
        <div class="card text-center">
          <div class="w-16 h-16 bg-yellow-100 dark:bg-yellow-900 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-yellow-600 dark:text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">响应式设计</h3>
          <p class="text-gray-600 dark:text-gray-400">
            完美适配桌面端和移动端，随时随地进行交易操作
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- CTA Section -->
  <div class="bg-gray-100 dark:bg-gray-800 py-20">
    <div class="container text-center">
      <h2 class="text-3xl font-bold mb-6">准备开始交易了吗？</h2>
      <p class="text-xl text-gray-600 dark:text-gray-400 mb-8 max-w-2xl mx-auto">
        注册账号，体验完整的加密货币交易流程
      </p>
      <a href="/register" class="btn btn-primary btn-lg">
        立即注册
      </a>
    </div>
  </div>

  <!-- Tech Stack -->
  <div class="py-20">
    <div class="container">
      <h2 class="text-3xl font-bold text-center mb-12">技术栈</h2>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 max-w-4xl mx-auto">
        <div class="text-center">
          <div class="text-5xl mb-3">⚡</div>
          <p class="font-medium">Astro</p>
        </div>
        <div class="text-center">
          <div class="text-5xl mb-3">⚛️</div>
          <p class="font-medium">React</p>
        </div>
        <div class="text-center">
          <div class="text-5xl mb-3">🗄️</div>
          <p class="font-medium">Supabase</p>
        </div>
        <div class="text-center">
          <div class="text-5xl mb-3">🎨</div>
          <p class="font-medium">Tailwind CSS</p>
        </div>
      </div>
    </div>
  </div>
</MainLayout>

