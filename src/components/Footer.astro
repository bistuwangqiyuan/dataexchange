---
/**
 * Footer Component
 * 网站页脚
 */
---

<footer class="bg-gray-900 text-gray-300 py-12 mt-auto">
  <div class="container">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- About -->
      <div>
        <h3 class="text-white font-bold mb-4">关于 CryptoEx</h3>
        <p class="text-sm leading-relaxed">
          教育演示版加密货币交易平台，使用真实市场数据，模拟交易环境。
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white font-bold mb-4">快速链接</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/markets" class="hover:text-primary-400">行情</a></li>
          <li><a href="/trade" class="hover:text-primary-400">交易</a></li>
          <li><a href="/wallet" class="hover:text-primary-400">钱包</a></li>
          <li><a href="/orders" class="hover:text-primary-400">订单</a></li>
        </ul>
      </div>

      <!-- Support -->
      <div>
        <h3 class="text-white font-bold mb-4">支持</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/docs" class="hover:text-primary-400">文档</a></li>
          <li><a href="/api" class="hover:text-primary-400">API</a></li>
          <li><a href="/faq" class="hover:text-primary-400">常见问题</a></li>
          <li><a href="/contact" class="hover:text-primary-400">联系我们</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="text-white font-bold mb-4">法律</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/terms" class="hover:text-primary-400">服务条款</a></li>
          <li><a href="/privacy" class="hover:text-primary-400">隐私政策</a></li>
          <li><a href="/disclaimer" class="hover:text-primary-400">免责声明</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-12 pt-8 border-t border-gray-800 flex flex-col md:flex-row justify-between items-center">
      <p class="text-sm text-gray-400">
        © 2024 CryptoEx. All rights reserved.
      </p>
      
      <div class="flex items-center space-x-6 mt-4 md:mt-0">
        <p class="text-xs text-yellow-500 font-medium">
          ⚠️ 教育演示项目 - 请勿用于实际交易
        </p>
      </div>
    </div>
  </div>
</footer>

