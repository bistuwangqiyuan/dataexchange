---
/**
 * Main Layout - 全局布局组件
 * 包含Header、Footer和主内容区域
 * 优化SEO，包含完整的meta标签和结构化数据
 */
import Header from '@/components/Header';
import Footer from '@/components/Footer.astro';
import SEOHead from '@/components/SEOHead.astro';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  image?: string;
  noindex?: boolean;
  canonical?: string;
}

const { 
  title, 
  description = 'Trade cryptocurrencies with confidence. Real-time market data, secure trading, and professional tools for Bitcoin, Ethereum, and more digital assets.',
  keywords,
  image,
  noindex = false,
  canonical
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- SEO Optimized Meta Tags -->
    <SEOHead 
      title={title}
      description={description}
      keywords={keywords}
      image={image}
      noindex={noindex}
      canonical={canonical}
    />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    
    <!-- Preconnect to external domains for performance -->
    <link rel="preconnect" href="https://api.coingecko.com" />
    <link rel="preconnect" href="https://api.binance.com" />
    
    <!-- DNS Prefetch -->
    <link rel="dns-prefetch" href="https://api.coingecko.com" />
    <link rel="dns-prefetch" href="https://api.binance.com" />
  </head>
  <body class="bg-gray-900 text-white min-h-screen flex flex-col">
    <Header client:load />
    
    <main class="flex-grow" id="main-content" role="main">
      <slot />
    </main>
    
    <Footer />
    
    <!-- Performance monitoring -->
    <script>
      // Report Core Web Vitals
      if ('PerformanceObserver' in window) {
        const observer = new PerformanceObserver((list) => {
          for (const entry of list.getEntries()) {
            // Log metrics for monitoring
            console.log(`${entry.name}: ${entry.value}`);
          }
        });
        
        try {
          observer.observe({ entryTypes: ['largest-contentful-paint', 'first-input', 'layout-shift'] });
        } catch (e) {
          // Browser doesn't support all metrics
        }
      }
    </script>
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
  }

  html {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    padding: 0;
  }

  /* Custom scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }

  ::-webkit-scrollbar-track {
    background: #1f2937;
  }

  ::-webkit-scrollbar-thumb {
    background: #4b5563;
    border-radius: 4px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: #6b7280;
  }
</style>
